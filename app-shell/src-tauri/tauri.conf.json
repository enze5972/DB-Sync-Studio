{
  "build": {
    "beforeDevCommand": "npm --prefix ../app-ui run dev",
    "beforeBuildCommand": "npm --prefix ../app-ui run build",
    "devPath": "http://localhost:5173",
    "distDir": "../../app-ui/dist"
  },
  "package": {
    "productName": "DB Sync Studio",
    "version": "0.1.0"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "identifier": "com.dbsyncstudio.app",
      "resources": [
        "resources/backend"
      ],
      "icon": [
        "icons/icon.ico",
        "icons/icon.icns",
        "icons/icon.png"
      ],
      "targets": "all"
    },
    "windows": [
      {
        "title": "DB Sync Studio",
        "width": 1440,
        "height": 960,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
